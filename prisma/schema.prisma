// StudyWithMe — Neon Postgres via Prisma

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hostedRooms   Room[]       @relation("RoomHost")
  roomMembers   RoomMember[]
  focusSessions FocusSession[]
  streak        Streak?

  @@map("users")
}

model Room {
  id               String   @id @default(cuid())
  code             String   @unique
  name             String
  isPublic         Boolean  @default(false)
  pomodoroDuration Int      @default(25)
  breakDuration    Int      @default(5)
  createdAt        DateTime @default(now())

  hostId String
  host   User   @relation("RoomHost", fields: [hostId], references: [id], onDelete: Cascade)

  members       RoomMember[]
  focusSessions FocusSession[]

  @@map("rooms")
}

model RoomMember {
  userId   String
  roomId   String
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@id([userId, roomId])
  @@map("room_members")
}

/// One completed Pomodoro (session log), per project context.
model FocusSession {
  id          String   @id @default(cuid())
  durationMin Int
  completedAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("focus_sessions")
}

model Streak {
  userId         String    @id
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActiveDate DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}
