{
  "name": "studywithme-socket-server",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "npm run prisma:generate && npm run typecheck",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema ../prisma/schema.prisma"
  },
  "type": "module",
  "private": true,
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "cookie": "^1.1.1",
    "dotenv": "^17.4.2",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
