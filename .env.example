# Runtime
NODE_ENV=development

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL_LOCAL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4001
NEXT_PUBLIC_SOCKET_URL_LOCAL=http://localhost:4001
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_URL_LOCAL=http://localhost:3000

# Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Data
DATABASE_URL=postgresql://user:password@localhost:5432/studywithme
PRISMA_DATABASE_URL=postgresql://user:password@localhost:5432/studywithme
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional feature toggles
AUTH_USE_TUNNEL=false
AUTH_USE_REDIS_SECONDARY=false
AUTH_USE_REDIS_RATELIMIT=true

# Optional frontend config
NEXT_PUBLIC_SOUNDS_BASE_URL=
NEXT_PUBLIC_RTC_ICE_SERVERS_JSON=

# Observability (optional in local dev)
OBS_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
GRAFANA_OTLP_ENDPOINT=
GRAFANA_OTLP_AUTH=
GRAFANA_LOKI_ENDPOINT=
GRAFANA_LOKI_USER=
GRAFANA_LOKI_API_KEY=

# QStash jobs (only if running jobs locally)
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
DATABASE_URL=
PRISMA_DATABASE_URL=
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4001
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Upstash QStash (scheduled jobs)
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Auth
AUTH_USE_REDIS_SECONDARY=false
AUTH_USE_REDIS_RATELIMIT=false


# note: nextconfig derives the socket url from NEXT_PUBLIC_SOCKET_URL_LOCAL
